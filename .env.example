DB_HOST=postgres_db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=team_manager
DB_NAME_DEV=team_manager_dev

# Google OAuth — from https://console.cloud.google.com/ → APIs & Services → Credentials
# The Client ID is used by both the API (JWT validation) and the UI (sign-in button)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MCP Server API key (generate via Profile → API Keys in the web app)
TEAM_MANAGER_API_KEY=tm_your-api-key-here
TEAM_MANAGER_API_URL=http://localhost:5000
