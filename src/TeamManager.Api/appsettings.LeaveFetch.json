{
  "LeaveFetch": {
    "Enabled": false,
    "Url": "https://example.com/api/leave",
    "Method": "POST",
    "IsFormUrlEncoded": true,
    "Headers": {
      "Cookie": "{cookie}",
      "Accept": "application/json, text/javascript, */*; q=0.01",
      "X-Requested-With": "XMLHttpRequest"
    },
    "BodyTemplate": "teamId={teamIds}&start={start}&end={end}",
    "Mapping": {
      "NamePath": "title",
      "StartPath": "start",
      "EndPath": "end",
      "TypePath": "type",
      "DaysPath": "totalDays",
      "StatusPath": "status",
      "NameTransform": "ExtractBeforeDash"
    }
  }
}
